local function getActiveFilterSignature()
    local collectedTokens = {}
    
    if type(Configurations.BuyPetsWhitelist) == "table" then
        for k, v in pairs(Configurations.BuyPetsWhitelist) do 
            if v == true or v == "true" then 
                table.insert(collectedTokens, "name_" .. tostring(k))
            end 
        end
    end
    
    if type(Configurations.BuyPetsSizeFilter) == "table" then
        for k, v in pairs(Configurations.BuyPetsSizeFilter) do 
            if v == true or v == "true" then 
                table.insert(collectedTokens, "size_" .. tostring(k))
            end 
        end
    end
    
    if type(Configurations.BuyPetsTypeFilter) == "table" then
        for k, v in pairs(Configurations.BuyPetsTypeFilter) do 
            if v == true or v == "true" then 
                table.insert(collectedTokens, "type_" .. tostring(k))
            end 
        end
    end
    
    table.sort(collectedTokens)
    return table.concat(collectedTokens, "|")
end

local function processAutoWalkPurchaseLoop()
    while Configurations.BuyPetsStatusEnabled do
        local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local rootPart = character:WaitForChild("HumanoidRootPart", 5)
        local humanoid = character:WaitForChild("Humanoid", 5)
        
        if not rootPart or not humanoid then 
            task.wait(0.5)
            continue 
        end
        
        local startingFilterSignature = getActiveFilterSignature()
        
        local wildPetSpawns = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("WildPetSpawns")
        local wildPetRef = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("WildPetRef")
        local targetPrompt = nil
        local targetPart = nil
        
        if wildPetSpawns then
            for _, spawnInstance in ipairs(wildPetSpawns:GetChildren()) do
                local prompt = spawnInstance:FindFirstChild("BuyPrompt", true) or spawnInstance:FindFirstChildOfClass("ProximityPrompt", true)
                
                if prompt and prompt:IsA("ProximityPrompt") then
                    local root = prompt.Parent:IsA("BasePart") and prompt.Parent or spawnInstance:FindFirstChildOfClass("BasePart")
                    
                    if root then
                        local spawnedGuid = spawnInstance.Name:match("([%x%-]+)$")
                        local companionRefInstance = spawnedGuid and wildPetRef and wildPetRef:FindFirstChild("WildPet_" .. spawnedGuid)
                        
                        local currentSize = "normal"
                        local currentType = "normal"
                        
                        if companionRefInstance then
                            local rawSize = companionRefInstance:GetAttribute("PetSize") or companionRefInstance:GetAttribute("Size")
                            local rawType = companionRefInstance:GetAttribute("PetType") or companionRefInstance:GetAttribute("Type")
                            
                            if rawSize and tostring(rawSize) ~= "" then currentSize = tostring(rawSize):lower() end
                            if rawType and tostring(rawType) ~= "" then currentType = tostring(rawType):lower() end
                        end
                        
                        local nameFilterActive = false
                        if type(Configurations.BuyPetsWhitelist) == "table" then
                            for _, active in pairs(Configurations.BuyPetsWhitelist) do if active == true then nameFilterActive = true break end end
                        end

                        local sizeFilterActive = false
                        if type(Configurations.BuyPetsSizeFilter) == "table" then
                            for _, active in pairs(Configurations.BuyPetsSizeFilter) do if active == true then sizeFilterActive = true break end end
                        end
                        
                        local typeFilterActive = false
                        if type(Configurations.BuyPetsTypeFilter) == "table" then
                            for _, active in pairs(Configurations.BuyPetsTypeFilter) do if active == true then typeFilterActive = true break end end
                        end
                        
                        local matchesName = false
                        local rawSpawnNameLower = spawnInstance.Name:lower()
                        
                        if type(Configurations.BuyPetsWhitelist) == "table" then
                            for whitelistedName, active in pairs(Configurations.BuyPetsWhitelist) do
                                if active == true then
                                    local cleanCheckedKey = tostring(whitelistedName):lower()
                                    if string.find(rawSpawnNameLower, cleanCheckedKey) then
                                        matchesName = true
                                        break
                                    end
                                end
                            end
                        end
                        
                        local titleSize = currentSize:gsub("^%l", string.upper)
                        local matchesSize = (Configurations.BuyPetsSizeFilter[currentSize] == true) or (Configurations.BuyPetsSizeFilter[titleSize] == true)
                        
                        local titleType = currentType:gsub("^%l", string.upper)
                        local matchesType = (Configurations.BuyPetsTypeFilter[currentType] == true) or (Configurations.BuyPetsTypeFilter[titleType] == true)
                        
                        local shouldTargetPet = false
                        
                        if sizeFilterActive or typeFilterActive then
                            local sizeMatchCondition = sizeFilterActive and matchesSize
                            local typeMatchCondition = typeFilterActive and matchesType
                            if sizeMatchCondition or typeMatchCondition then shouldTargetPet = true end
                        end

                        if nameFilterActive and matchesName then
                            shouldTargetPet = true
                        end
                        
                        if shouldTargetPet then
                            targetPrompt = prompt
                            targetPart = root
                            break
                        end
                    end
                end
            end
        end
        if targetPart and targetPrompt then
            local originalCollisions = {}
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    originalCollisions[part] = part.CanCollide
                    part.CanCollide = false
                end
            end
            
            local currentHeightOffset = 3.2
            local currentPos = rootPart.Position
            local targetPos = targetPart.Position + Vector3.new(0, currentHeightOffset, 0)
            
            local distance = (targetPos - currentPos).Magnitude
            local speed = tonumber(Configurations.BuyPetsSpeed) or 50
            if speed <= 0 then speed = 50 end
            local duration = distance / speed
            
            rootPart.CFrame = CFrame.lookAt(currentPos, Vector3.new(targetPos.X, currentPos.Y, targetPos.Z))
            
            local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
            local targetCFrame = CFrame.new(targetPos) * CFrame.Angles(0, math.rad(rootPart.Orientation.Y), 0)
            local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = targetCFrame})
            
            tween:Play()
            
            local wasCancelled = false
            local statusConn
            statusConn = AutoBuyActionFrame.MouseButton1Click:Connect(function()
                if not Configurations.BuyPetsStatusEnabled then
                    tween:Cancel()
                    wasCancelled = true
                end
            end)

            while tween.PlaybackState == Enum.PlaybackState.Playing do
                if startingFilterSignature ~= getActiveFilterSignature() or not Configurations.BuyPetsStatusEnabled then
                    tween:Cancel()
                    wasCancelled = true
                    break
                end
                task.wait()
            end
            statusConn:Disconnect()
            
            if wasCancelled or not Configurations.BuyPetsStatusEnabled then
                rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                for part, originalState in pairs(originalCollisions) do
                    if part and part.Parent then part.CanCollide = originalState end
                end
                humanoid.Jump = true
                if startingFilterSignature ~= getActiveFilterSignature() then task.wait(0.1) continue end
                break
            end
            
            if Configurations.BuyPetsStatusEnabled and targetPart:IsDescendantOf(workspace) then
                targetPrompt.RequiresLineOfSight = false 
                targetPrompt.ClickablePrompt = true       
                
                while Configurations.BuyPetsStatusEnabled and targetPart:IsDescendantOf(workspace) and targetPrompt:IsDescendantOf(workspace) do
                    if startingFilterSignature ~= getActiveFilterSignature() or not Configurations.BuyPetsStatusEnabled then 
                        targetPrompt:InputHoldEnd()
                        break 
                    end

                    local escortPetCFrame = targetPart.CFrame
                    local balancedEscortPos = escortPetCFrame.Position + Vector3.new(0, 3.2, 0)
                    rootPart.CFrame = CFrame.new(balancedEscortPos) * CFrame.Angles(0, math.rad(escortPetCFrame.Rotation.Y), 0)
                    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)

                    targetPrompt:InputHoldBegin()
                    local triggerPrompt = fireproximityprompt or _G.fireproximityprompt
                    if triggerPrompt then
                        triggerPrompt(targetPrompt)
                    else
                        targetPrompt:InputHoldEnd()
                    end
                    
                    task.wait() 
                end
            end
            
            rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            
            for part, originalState in pairs(originalCollisions) do
                if part and part.Parent then
                    part.CanCollide = originalState
                end
            end
            
            humanoid.Jump = true
            task.wait(0.1)
        else
            task.wait(0.3)
        end
    end
end

