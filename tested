local function buildPopUpSelectionRegistry()
    for _, oldButton in ipairs(BuyPetsScroll:GetChildren()) do if oldButton:IsA("TextButton") then oldButton:Destroy() end end
    local petsFolder = ReplicatedStorage:FindFirstChild("Assets") and ReplicatedStorage.Assets:FindFirstChild("Pets")
    if petsFolder then
        local catIndex = 1
        for _, petModel in ipairs(petsFolder:GetChildren()) do
            local pName = petModel.Name
            local filterRow = Instance.new("TextButton")
            filterRow.Size = UDim2.new(1, 0, 0, 34)
            filterRow.Text = ""
            filterRow.LayoutOrder = catIndex
            filterRow.Parent = BuyPetsScroll
            filterRow:SetAttribute("ItemName", pName)
            local frCorner = Instance.new("UICorner")
            frCorner.CornerRadius = UDim.new(0, 6)
            frCorner.Parent = filterRow
            local filterLabel = Instance.new("TextLabel")
            filterLabel.Size = UDim2.new(1, -20, 1, 0)
            filterLabel.Position = UDim2.new(0, 10, 0, 0)
            filterLabel.BackgroundTransparency = 1
            filterLabel.Text = pName 
            filterLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
            filterLabel.TextSize = 11
            filterLabel.Font = Enum.Font.SourceSansBold
            filterLabel.TextXAlignment = Enum.TextXAlignment.Left
            filterLabel.Parent = filterRow
            if Configurations.BuyPetsWhitelist[pName] == nil then Configurations.BuyPetsWhitelist[pName] = false end
            local function updateFilterRowVisuals()
                local isSelected = Configurations.BuyPetsWhitelist[pName] or false
                if isSelected then
                    filterRow.BackgroundColor3 = Color3.fromRGB(0, 80, 180)
                    filterLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                else
                    filterRow.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
                    filterLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
                end
                if not hasSelectedPetsInConfig() and Configurations.BuyPetsStatusEnabled then
                    Configurations.BuyPetsStatusEnabled = false
                    updateAutoBuyButtonVisuals()
                end
            end
            updateFilterRowVisuals()
            filterRow.MouseButton1Click:Connect(function()
                Configurations.BuyPetsWhitelist[pName] = not Configurations.BuyPetsWhitelist[pName]
                updateFilterRowVisuals()
                saveSystemConfigurations()
            end)
            catIndex = catIndex + 1
        end
    end
end

