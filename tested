-- [[ LOAD CONFIG ]]
local function loadSystemConfigurations()
    if type(Configurations.BuySeedsWhitelist) ~= "table" then Configurations.BuySeedsWhitelist = {} end
    if Configurations.AutoBuySeedsEnabled == nil then Configurations.AutoBuySeedsEnabled = false end

    pcall(function()
        if readfile and isfile and isfile(filePath) then
            local json = readfile(filePath)
            local decoded = HttpService:JSONDecode(json)
            
            if decoded then
                for key, value in pairs(decoded) do
                    if type(value) ~= "table" then
                        Configurations[key] = value
                    end
                end

                local tableKeys = {"FruitWhitelist", "MutationFilter", "SellFruitWhitelist", "SellMutationFilter", "BuyPetsWhitelist", "BuyPetsSizeFilter", "BuyPetsTypeFilter", "BuySeedsWhitelist", "BuyGearWhitelist", "BuyCratesWhitelist", "MailboxSelectedGifts", "AuctionSelectedType", "PlantingSelectedSeeds", "SelectedFruitsToDrop", "SelectedItemsToEsp", "SelectedPlantsToTrowel"}
                for _, tblName in ipairs(tableKeys) do
                    if decoded[tblName] and type(decoded[tblName]) == "table" then
                        Configurations[tblName] = {}
                        for itemKey, activeState in pairs(decoded[tblName]) do
                            Configurations[tblName][itemKey] = activeState
                        end
                    else
                        if type(Configurations[tblName]) ~= "table" then
                            Configurations[tblName] = {}
                        end
                    end
                end
            end
        end
    end)
end
loadSystemConfigurations()

