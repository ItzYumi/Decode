local function trackHumanoid(character)
    if not character then return end
    local humanoid = character:WaitForChild("Humanoid", 5) or character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        if not Configurations.SpeedEnabled then
            if ConnectionTokens["SpeedChange"] then
                ConnectionTokens["SpeedChange"]:Disconnect()
                ConnectionTokens["SpeedChange"] = nil
            end
            return
        end
        humanoid.WalkSpeed = Configurations.CurrentSpeed
        if ConnectionTokens["SpeedChange"] then
            ConnectionTokens["SpeedChange"]:Disconnect()
        end
        ConnectionTokens["SpeedChange"] = humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if Configurations.SpeedEnabled then 
                if humanoid.WalkSpeed ~= Configurations.CurrentSpeed then humanoid.WalkSpeed = Configurations.CurrentSpeed end
            else 
                if ConnectionTokens["SpeedChange"] then
                    ConnectionTokens["SpeedChange"]:Disconnect()
                    ConnectionTokens["SpeedChange"] = nil
                end 
            end
        end)
    end
end

