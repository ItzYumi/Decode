    _G.DropSystemPool.UpdateTypeSelectBtnText = function()
        local count = 0
        local seenKeys = {}
        if type(Configurations.SelectedFruitsToDrop) == "table" then
            for key, state in pairs(Configurations.SelectedFruitsToDrop) do
                if type(key) == "string" and state == true and not seenKeys[key] then
                    seenKeys[key] = true
                    count = count + 1
                elseif type(key) == "number" and type(state) == "string" and not seenKeys[state] then
                    seenKeys[state] = true
                    count = count + 1
                end
            end
        end
        if count == 0 then
            _G.DropSystemPool.TypeSelectBtn.Text = "SELECT ITEMS"
            _G.DropSystemPool.TypeSelectBtn.BackgroundColor3 = Color3.fromRGB(32, 32, 35)
        else
            _G.DropSystemPool.TypeSelectBtn.Text = "SELECTED: " .. tostring(count)
            _G.DropSystemPool.TypeSelectBtn.BackgroundColor3 = Color3.fromRGB(0, 145, 255)
        end
    end
    _G.DropSystemPool.PopulateDropItemsEngine = function()
        for _, oldObj in ipairs(_G.DropSystemPool.SelectorScrollFrame:GetChildren()) do
            if not oldObj:IsA("UIListLayout") then oldObj:Destroy() end
        end
        
        local targetCategories = {"Plants", "Seeds", "Pets", "Sprinklers", "WateringCans"}
        local globalUIOrder = 1
        
        for _, categoryName in ipairs(targetCategories) do
            local folder = game:GetService("ReplicatedStorage"):FindFirstChild("Assets")
            folder = folder and folder:FindFirstChild(categoryName)
            if folder then
                local children = folder:GetChildren()
                if #children > 0 then
                    local catHeader = Instance.new("TextLabel")
                    catHeader.Size = UDim2.new(1, 0, 0, 22)
                    catHeader.BackgroundTransparency = 1
                    if categoryName == "Plants" then
                        catHeader.Text = "--- FRUITS ---"
                    else
                        catHeader.Text = string.format("--- %s ---", categoryName:upper())
                    end
                    catHeader.TextColor3 = Color3.fromRGB(0, 150, 255)
                    catHeader.TextSize = 12
                    catHeader.Font = Enum.Font.SourceSansBold
                    catHeader.TextXAlignment = Enum.TextXAlignment.Center
                    catHeader.LayoutOrder = globalUIOrder
                    catHeader.Parent = _G.DropSystemPool.SelectorScrollFrame
                    globalUIOrder = globalUIOrder + 1
                    
                    for _, asset in ipairs(children) do
                        local name = asset.Name
                        if name ~= "None" and name ~= "Default" and name ~= "" then
                            local compositeKey = categoryName .. "_" .. name
                            local row = Instance.new("TextButton")
                            row.Size = UDim2.new(1, -10, 0, 32)
                            row.Position = UDim2.new(0, 5, 0, 0)
                            row.LayoutOrder = globalUIOrder
                            row.Text = "       " .. name
                            row.TextSize = 12
                            row.Font = Enum.Font.SourceSansBold
                            row.TextXAlignment = Enum.TextXAlignment.Left
                            row.Parent = _G.DropSystemPool.SelectorScrollFrame
                            row:SetAttribute("ItemName", name)
                            
                            local rowCorner = Instance.new("UICorner")
                            rowCorner.CornerRadius = UDim.new(0, 6)
                            rowCorner.Parent = row
                            
                            local function checkIsActive()
                                if type(Configurations.SelectedFruitsToDrop) ~= "table" then return false end
                                if Configurations.SelectedFruitsToDrop[compositeKey] == true then return true end
                                for _, value in pairs(Configurations.SelectedFruitsToDrop) do
                                    if value == compositeKey then return true end
                                end
                                return false
                            end
                            
                            local function updateRowStyle()
                                local active = checkIsActive()
                                row.BackgroundColor3 = active and Color3.fromRGB(0, 145, 255) or Color3.fromRGB(24, 24, 28)
                                row.TextColor3 = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(220, 220, 225)
                            end
